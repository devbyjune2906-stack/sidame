# Kredensial PostgreSQL (dipakai oleh service "db" di docker-compose.yml,
# dan dirakit otomatis menjadi DATABASE_URL untuk service "app")
POSTGRES_USER="sidame"
POSTGRES_PASSWORD="ganti-dengan-password-yang-kuat"
POSTGRES_DB="sidame"

# Untuk menjalankan TANPA docker-compose (mis. npm run dev lokal),
# isi DATABASE_URL lengkap di sini:
# DATABASE_URL="postgresql://user:password@localhost:5432/sidame"

# Rahasia untuk menandatangani session JWT — buat dengan: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-string-acak-yang-panjang"

# Akun Admin awal (dipakai script seed)
SEED_ADMIN_EMAIL="admin@sidame.go.id"
SEED_ADMIN_PASSWORD="ubah-password-ini"
SEED_ADMIN_NAMA="Administrator"
